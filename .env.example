# Suno API credentials for generate.py
# Copy to .env and fill values.

# --- Recommended: Cookie-based auto-refresh (tokens never manually expire) ---
# 1. In browser on suno.com, DevTools > Network > any studio-api request
# 2. Copy the full "Cookie: ..." request header value (long string with __client, __session etc.)
# 3. Run: scripts/set-suno-cookies   (or paste here)
# These cookies usually last days/weeks. The script auto-exchanges them for fresh JWTs via Clerk on every use.
SUNO_COOKIE=

# Optional but recommended for the full "Automatic token maintenance and keep-alive":
# Provide the Clerk session id (usually starts with sess_...) to use the direct
# POST /client/sessions/{id}/tokens mint endpoint (the mechanism used by
# https://github.com/SunoAI-API/Suno-API for proactive keep-alive).
# You can discover it by running once with SUNO_COOKIE; the script will print the discovered id.
# Or extract from browser localStorage / cookies / the /client JSON response.
SUNO_SESSION_ID=

# --- Fallback (not recommended for regular use) ---
# Manual short-lived JWT. Expires ~1h. Use only if cookie method is unavailable.
# Obtain via scripts/suno-token-snippet.js or by copying Authorization: Bearer ...
SUNO_AUTH_TOKEN=

# Device ID (from browser, same request headers)
SUNO_DEVICE_ID=

# Defaults (rarely need to change)
SUNO_MODEL=chirp-crow
SUNO_API_URL=https://studio-api.prod.suno.com

# --- For running the keep-alive daemon (optional) ---
# python generate.py --keep-alive
# This will loop calling Clerk to keep a fresh token and exercise session maintenance
# every few seconds. Useful for long-running wrappers or to keep cookies "warm".
# You can run it in a separate terminal/tmux:  python generate.py --keep-alive
# It supports SUNO_COOKIE + SUNO_SESSION_ID for best results (matches the Suno-API keep-alive).
